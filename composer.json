{
    "name": "thanhtungtav4/pixel-cam-child",
    "description": "Pixel Cam — WordPress child theme for camera/electronics e-commerce (WooCommerce + ACF + Inertia-style page building).",
    "type": "wordpress-theme",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "squizlabs/php_codesniffer": "^3.7",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "stan": "phpstan analyse",
        "i18n": "bin/build-translations.sh",
        "acf:validate": "php acf-json/validate.php"
    },
    "support": {
        "source": "https://github.com/thanhtungtav4/Omnichannel",
        "issues": "https://github.com/thanhtungtav4/Omnichannel/issues"
    }
}
