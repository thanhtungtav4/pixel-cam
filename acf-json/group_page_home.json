                {
                    "key": "field_page_home_products_link",
                    "label": "Link xem thêm",
                    "name": "link",
                    "type": "link",
                    "return_format": "array",
                    "wrapper": { "width": "50" }
                },
                {
                    "key": "field_page_home_products_mode",
                    "label": "Chế độ chọn sản phẩm",
                    "name": "mode",
                    "type": "select",
                    "choices": {
                        "auto": "Tự động (bán chạy nhất)",
                        "manual": "Chọn tay"
                    },
                    "default_value": "auto",
                    "wrapper": { "width": "50" }
                },
                {
                    "key": "field_page_home_products_count",
                    "label": "Số sản phẩm (chế độ tự động)",
                    "name": "count",
                    "type": "number",
                    "default_value": 6,
                    "min": 1,
                    "max": 24,
                    "wrapper": { "width": "50" },
                    "conditional_logic": [
                        [
                            { "field": "field_page_home_products_mode", "operator": "==", "value": "auto" }
                        ]
                    ]
                },
                {
                    "key": "field_page_home_products_manual",
                    "label": "Sản phẩm chọn tay",
                    "name": "manual_products",
                    "type": "relationship",
                    "post_type": ["product"],
                    "filters": ["search"],
                    "return_format": "id",
                    "conditional_logic": [
                        [
                            { "field": "field_page_home_products_mode", "operator": "==", "value": "manual" }
                        ]
                    ]
                }
            ]
        },
