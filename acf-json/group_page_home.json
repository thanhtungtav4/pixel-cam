                    "name": "mode",
                    "type": "select",
                    "choices": {
                        "auto": "Tự động (mới nhất)",
                        "manual": "Chọn tay"
                    },
                    "default_value": "auto",
                    "wrapper": { "width": "50" }
                },
                {
                    "key": "field_page_home_blog_count",
                    "label": "Số bài (chế độ tự động)",
                    "name": "count",
                    "type": "number",
                    "default_value": 6,
                    "min": 1,
                    "max": 6,
                    "wrapper": { "width": "50" },
                    "conditional_logic": [
                        [
                            { "field": "field_page_home_blog_mode", "operator": "==", "value": "auto" }
                        ]
                    ]
                },
                {
                    "key": "field_page_home_blog_manual",
                    "label": "Bài viết chọn tay (bài đầu = bài lớn, tối đa 6)",
                    "name": "manual_posts",
                    "type": "relationship",
                    "post_type": ["post"],
                    "filters": ["search"],
                    "return_format": "id",
                    "max": 6,
                    "conditional_logic": [
                        [
                            { "field": "field_page_home_blog_mode", "operator": "==", "value": "manual" }
                        ]
                    ]
                }
